<?xml version="1.0"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="LOC_Ludu_MenuLink">Link Unified Manifest File</sys:String>
    <sys:String x:Key="LOC_Ludu_MenuAdd">Add Save Path to Manifest</sys:String>
    <sys:String x:Key="LOC_Ludu_SelectManifestTitle">Please select your existing unified Manifest file</sys:String>
    <sys:String x:Key="LOC_Ludu_LinkSuccessMsg" xml:space="preserve">Successfully linked!&#x0a;New rules will be appended to:&#x0a;{0}</sys:String>
    <sys:String x:Key="LOC_Ludu_SetupComplete">Setup Complete</sys:String>
    <sys:String x:Key="LOC_Ludu_ErrNotConfiguredMsg">Please click the [Link Manifest File] button first!</sys:String>
    <sys:String x:Key="LOC_Ludu_NotConfigured">Not Configured</sys:String>
    <sys:String x:Key="LOC_Ludu_ErrMissingMsg" xml:space="preserve">The linked file path is invalid or the file has been moved.&#x0a;Path: [{0}]</sys:String>
    <sys:String x:Key="LOC_Ludu_FileMissing">File Missing</sys:String>
    <sys:String x:Key="LOC_Ludu_SelectTypeMsg" xml:space="preserve">Are you adding an entire folder or a single file?&#x0a;&#x0a;[Yes] = Folder&#x0a;[No] = File</sys:String>
    <sys:String x:Key="LOC_Ludu_SelectType">Select Type</sys:String>
    <sys:String x:Key="LOC_Ludu_SetWildcardMsg" xml:space="preserve">Selected path: {0} &#x0a;&#x0a;Please enter the matching rule (Glob):&#x0a; * -> All contents in folder&#x0a; *.sav        -> Only .sav extensions&#x0a; save_*.dat   -> Files starting with save_</sys:String>
    <sys:String x:Key="LOC_Ludu_SetWildcard">Set Wildcard</sys:String>
    <sys:String x:Key="LOC_Ludu_SuccessMsg" xml:space="preserve">Appended to: {0}&#x0a;&#x0a;Rule: {1}</sys:String>
    <sys:String x:Key="LOC_Ludu_Success">Success</sys:String>
    <sys:String x:Key="LOC_Ludu_WriteFailMsg">Write failed: {0}</sys:String>
    <sys:String x:Key="LOC_Ludu_Error">Error</sys:String>
</ResourceDictionary>